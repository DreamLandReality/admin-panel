# Dream Land Reality Admin Panel - Environment Variables

# ─── Supabase (Required) ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


# ─── Anthropic AI (Required for AI Parsing) ──────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-api03-your_key_here


# ─── Google AI (Optional — Enables Gemini as alternative parser) ─────────────
# Get from: https://aistudio.google.com/app/apikey
# Gemini 2.0 Flash is faster and cheaper than Claude, but slightly less accurate
# for complex real estate descriptions. Both providers are fully supported.

GOOGLE_API_KEY=your_google_api_key_here


# ─── GitHub (Required for Template Deployment) ───────────────────────────────
# Create token: https://github.com/settings/tokens
# Scopes needed: repo, workflow

GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org-name
# OR use username if not using organization:
# GITHUB_USERNAME=your-username


# ─── Cloudflare (Optional - Enables Auto-Deployment) ─────────────────────────
# Create token: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Account > Cloudflare Pages > Edit

CLOUDFLARE_API_TOKEN=your_cloudflare_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here


# ─── Cloudflare R2 Storage (Required for Image Display & Uploads) ─────────────
# Create R2 buckets: https://dash.cloudflare.com/r2
# Create API token:  R2 → Manage R2 API Tokens → Create API Token
#
# Two buckets are required:
#   screenshots  (PRIVATE) — template catalog previews + deployment screenshots (signed URLs)
#   assets       (PUBLIC)  — customer image uploads + template images (CDN URL)
#
# CLOUDFLARE_ACCOUNT_ID is shared with the Cloudflare Pages config above.

CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Private bucket — all screenshots: template previews + deployment screenshots (signed URLs)
CLOUDFLARE_R2_BUCKET_NAME=screenshots

# Public bucket — customer image uploads + template images
CLOUDFLARE_R2_ASSETS_BUCKET_NAME=assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-your-hash.r2.dev


# ─── Voice Agent (ElevenLabs + Twilio) ──────────────────────────────────────
# ElevenLabs: https://elevenlabs.io → Profile → API Keys
# Create agent: Conversational AI → Agents → Create Agent
# Connect Twilio: Phone Numbers → Connect Twilio

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=


# ─── Job Scheduling (QStash by Upstash) ─────────────────────────────────────
# Get from: https://console.upstash.com → QStash

QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=


# ─── Development (Optional) ───────────────────────────────────────────────────

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable debug mode
DEBUG=false
